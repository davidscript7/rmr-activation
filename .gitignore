# ─────────────────────────────────────────────────────────
#  RMR Activation — .gitignore
#  Power Query + SharePoint Lists version
# ─────────────────────────────────────────────────────────

# Real config (contains sensitive credentials, paths, GUIDs)
config.json

# RMR Master file (contains real operational data and connections)
input/RMR_Master.xlsm
RMR_Master.xlsm

# Microsoft auth token cache
.token_cache.bin

# Intermediate data files generated between steps
input/.step1_data.json
input/.step2_data.json

# Input folder — SAP exports and operational files
input/*.xlsx
input/*.xls
input/*.xlsm

# Output folder — generated files
output/
!output/.gitkeep

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
venv/
.venv/
env/
.env/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
.vscode/
.idea/
*.swp
*.swo

# Excel temporary files
~$*.xlsx
~$*.xlsm
~$*.xls

# Backup files
*.bak
*.backup